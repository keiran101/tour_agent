# =============================================================================
# Tour Agent Configuration
# =============================================================================

# Application
APP_ENV=development
PROJECT_NAME="Tour Agent"
VERSION=0.1.0
DEBUG=true
API_V1_STR=/api/v1

# CORS
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# =============================================================================
# LLM (OpenAI-compatible protocol)
# =============================================================================
LLM_API_KEY="your-api-key"
LLM_BASE_URL="https://api.siliconflow.cn/v1"
DEFAULT_LLM_MODEL=MiMo-V2.5

# Agent
AGENT_MAX_STEPS=15
DEFAULT_LLM_TEMPERATURE=0.2
MAX_TOKENS=4096
MAX_LLM_CALL_RETRIES=3
LLM_TOTAL_TIMEOUT=120

# Embedding (for memory/pgvector)
EMBEDDING_API_KEY=""
EMBEDDING_BASE_URL=""
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
MEMORY_COLLECTION_NAME=longterm_memory

# =============================================================================
# External APIs (tour-specific tools)
# =============================================================================
AMAP_API_KEY="your-amap-key"
GOOGLE_PLACES_API_KEY="your-google-places-key"
QWEATHER_API_KEY="your-qweather-key"
TAVILY_API_KEY="your-tavily-key"

# =============================================================================
# Langfuse (observability)
# =============================================================================
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# =============================================================================
# Auth
# =============================================================================
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30
SESSION_NAMING_ENABLED=true

# =============================================================================
# Database (PostgreSQL + pgvector)
# =============================================================================
POSTGRES_HOST=db
POSTGRES_DB=tour_agent_db
POSTGRES_USER=postgres
POSTGRES_PORT=5432
POSTGRES_PASSWORD=postgres
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# =============================================================================
# Cache (optional, set VALKEY_HOST to enable)
# =============================================================================
# VALKEY_HOST=valkey

# =============================================================================
# Rate Limiting
# =============================================================================
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=console
